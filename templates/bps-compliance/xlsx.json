{
  "$comment": "BPS Compliance Excel companion spec — controls sheet names, column order, formats, and charts for asset managers, counsel, and compliance consultants tracking Local Law 97, DC BEPS, Chicago, Denver, and similar building performance standards. Critical output: penalty exposure dollarized and visible.",

  "filename_pattern": "BPS_Compliance_{asset}_{YYYY-MM-DD}.xlsx",

  "sheets": [

    {
      "id": "compliance_summary",
      "name": "Compliance Summary",
      "order": 1,
      "type": "key_value",
      "description": "Cover-page snapshot of regulatory status and current penalty exposure. Designed for asset managers and board-level review.",
      "rows": [
        { "label": "Property",            "data_path": "property.name" },
        { "label": "Address",             "data_path": "property.address" },
        { "label": "Asset Type",          "data_path": "property.type" },
        { "label": "GFA (sqft)",          "data_path": "property.gfa_sqft",                   "format": "#,##0" },
        { "label": "Jurisdiction",        "data_path": "property.jurisdiction.city" },
        { "label": "",                    "type": "spacer" },
        { "label": "Regulation",          "data_path": "regulation.name" },
        { "label": "Enforcing Authority", "data_path": "regulation.authority" },
        { "label": "Compliance Start",    "data_path": "regulation.compliance_start_year" },
        { "label": "Reporting Cycle",     "data_path": "regulation.reporting_cycle" },
        { "label": "Penalty Rate",        "data_path": "regulation.penalty_rate_usd_per_tco2e","format": "$#,##0", "omit_if_null": true },
        { "label": "",                    "type": "spacer" },
        { "label": "Performance Year",    "data_path": "current_performance.performance_year", "omit_if_null": true },
        { "label": "Actual Emissions",    "data_path": "current_performance.actual_emissions_tco2e", "format": "#,##0.0", "omit_if_null": true },
        { "label": "Threshold",           "data_path": "current_performance.benchmark_threshold", "format": "#,##0.0", "omit_if_null": true },
        { "label": "Compliance Status",   "data_path": "current_performance.compliance_status", "style": "compliance_status" },
        { "label": "Penalty / Year",      "data_path": "current_performance.penalty_per_year_usd", "format": "$#,##0", "style": "penalty_if_nonzero", "omit_if_null": true },
        { "label": "Data Source",         "data_path": "current_performance.data_source",     "omit_if_null": true },
        { "label": "",                    "type": "spacer" },
        { "label": "Report Date",         "data_path": "report_date" },
        { "label": "Prepared By",         "data_path": "prepared_by" },
        { "label": "Prepared For",        "data_path": "prepared_for" }
      ],
      "columns": [
        { "header": "Field",  "width": 24 },
        { "header": "Value",  "width": 64, "wrap": true }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" },
        "value_column": { "fill": "none" },
        "compliance_status_row": {
          "bold": true,
          "fill_by_value": {
            "compliant":     "#D1FAE5",
            "at-risk":       "#FFFBEB",
            "non-compliant": "#FEE2E2"
          }
        },
        "penalty_if_nonzero_row": {
          "bold": true,
          "fill": "#FEE2E2",
          "font_color": "#991B1B",
          "condition": "value > 0"
        }
      }
    },

    {
      "id": "compliance_periods",
      "name": "Compliance Periods",
      "order": 2,
      "type": "table",
      "description": "Projected compliance status and penalty exposure by regulatory period. Board-level view of penalty risk across compliance cycles.",
      "data_path": "compliance_periods",
      "columns": [
        { "header": "Period",                        "data_key": "period_label",             "width": 16 },
        { "header": "Threshold (tCO₂e)",        "data_key": "threshold_tco2e",           "width": 20, "format": "#,##0.0" },
        { "header": "Projected Emissions (tCO₂e)", "data_key": "projected_emissions_tco2e", "width": 24, "format": "#,##0.0" },
        { "header": "Variance (tCO₂e)",         "data_key": "_computed_variance",        "width": 20, "format": "#,##0.0", "compute": "projected_emissions_tco2e - threshold_tco2e" },
        { "header": "Projected Annual Penalty ($)",  "data_key": "projected_penalty_usd",    "width": 26, "format": "$#,##0" },
        { "header": "Compliance Status",             "data_key": "compliance_status",        "width": 20 }
      ],
      "totals_row": {
        "label_column": "period_label",
        "label": "TOTAL",
        "sum_columns": ["projected_penalty_usd"],
        "format": "$#,##0",
        "bold": true,
        "fill": "primary"
      },
      "conditional_formatting": {
        "compliance_status": {
          "compliant":     { "fill": "#D1FAE5", "font_color": "#065F46" },
          "at-risk":       { "fill": "#FFFBEB", "font_color": "#92400E" },
          "non-compliant": { "fill": "#FEE2E2", "font_color": "#991B1B" }
        },
        "projected_penalty_usd": {
          "rule": "gradient",
          "min_value": 0,
          "min_color": "#FFFFFF",
          "max_color": "#FCA5A5"
        }
      },
      "charts": [
        {
          "id": "penalty_by_period",
          "type": "BarChart",
          "title": "Projected Annual Penalty by Compliance Period",
          "x_axis": "period_label",
          "y_axis": "projected_penalty_usd",
          "aggregate": "sum",
          "y_axis_label": "Projected Annual Penalty ($)",
          "series_color": "#DC2626",
          "placement": "right_of_table",
          "width_cols": 10,
          "height_rows": 18
        }
      ],
      "freeze_panes": "B2",
      "note": "Penalties are projected based on current trajectory absent additional measures. See Pathway to Compliance sheet for mitigation options."
    },

    {
      "id": "penalty_projection",
      "name": "Penalty Projection",
      "order": 3,
      "type": "table",
      "description": "Year-by-year penalty table showing the cumulative cost of inaction. Used to frame urgency of compliance investment.",
      "data_path": "penalty_projection",
      "columns": [
        { "header": "Year",                          "data_key": "year",                      "width": 10 },
        { "header": "Threshold (tCO₂e)",        "data_key": "threshold_tco2e",           "width": 20, "format": "#,##0.0" },
        { "header": "Projected Emissions (tCO₂e)", "data_key": "projected_emissions_tco2e", "width": 24, "format": "#,##0.0" },
        { "header": "Annual Penalty ($)",            "data_key": "annual_penalty_usd",        "width": 20, "format": "$#,##0" },
        { "header": "Cumulative Penalty ($)",        "data_key": "cumulative_penalty_usd",    "width": 22, "format": "$#,##0" }
      ],
      "row_style": {
        "current_year": {
          "match": { "field": "year", "equals": "current_year" },
          "bold": true,
          "fill": "#FEF3C7"
        }
      },
      "conditional_formatting": {
        "cumulative_penalty_usd": {
          "rule": "gradient",
          "min_value": 0,
          "min_color": "#FEF9C3",
          "max_color": "#DC2626",
          "note": "Red gradient intensifies as cumulative liability grows — communicates the cost of delay."
        }
      },
      "charts": [
        {
          "id": "cumulative_penalty",
          "type": "LineChart",
          "title": "Cumulative Penalty Exposure — Cost of Inaction",
          "x_axis": "year",
          "y_axis": "cumulative_penalty_usd",
          "y_axis_label": "Cumulative Penalty ($)",
          "series_color": "#DC2626",
          "show_markers": true,
          "placement": "right_of_table",
          "width_cols": 10,
          "height_rows": 18
        }
      ],
      "freeze_panes": "B2",
      "note": "Cumulative figures assume no compliance action is taken. Actual exposure will vary based on future grid decarbonization, regulatory amendments, and capital improvements."
    },

    {
      "id": "pathway_to_compliance",
      "name": "Pathway to Compliance",
      "order": 4,
      "type": "table",
      "description": "Ordered capital measures that close the compliance gap, ranked by emissions reduction impact. Used to prioritize CapEx and demonstrate compliance strategy to counsel.",
      "data_path": "pathway_to_compliance",
      "columns": [
        { "header": "Measure",                        "data_key": "measure",                   "width": 36, "wrap": true },
        { "header": "CapEx ($)",                      "data_key": "capex",                     "width": 16, "format": "$#,##0" },
        { "header": "Annual Savings ($)",             "data_key": "annual_savings_usd",        "width": 18, "format": "$#,##0", "omit_if_all_null": true },
        { "header": "Emissions Reduction (tCO₂e)","data_key": "emissions_reduction_tco2e", "width": 24, "format": "#,##0.0" },
        { "header": "% Gap Closed",                  "data_key": "closes_gap_pct",            "width": 16, "format": "0.0%" },
        { "header": "Running Total Closed (%)",       "data_key": "running_gap_closed_pct",    "width": 22, "format": "0.0%" },
        { "header": "Implementation Year",            "data_key": "implementation_year",       "width": 20 }
      ],
      "totals_row": {
        "label_column": "measure",
        "label": "TOTAL",
        "sum_columns": ["capex", "annual_savings_usd", "emissions_reduction_tco2e"],
        "format_by_column": {
          "capex": "$#,##0",
          "annual_savings_usd": "$#,##0",
          "emissions_reduction_tco2e": "#,##0.0"
        },
        "bold": true,
        "fill": "primary"
      },
      "conditional_formatting": {
        "running_gap_closed_pct": {
          "rule": "gradient",
          "min_value": 0,
          "min_color": "#FEF9C3",
          "mid_value": 0.5,
          "mid_color": "#BBF7D0",
          "max_value": 1.0,
          "max_color": "#15803D",
          "note": "Green deepens as cumulative gap closure approaches 100% — shows path to full compliance."
        }
      },
      "sort": {
        "column": "emissions_reduction_tco2e",
        "direction": "descending"
      },
      "charts": [
        {
          "id": "reduction_by_measure",
          "type": "BarChart",
          "title": "Emissions Reduction by Measure (tCO₂e/yr)",
          "x_axis": "measure",
          "y_axis": "emissions_reduction_tco2e",
          "sort": "descending",
          "y_axis_label": "Annual Reduction (tCO₂e)",
          "series_color": "#15803D",
          "placement": "below_table",
          "width_cols": 16,
          "height_rows": 18
        }
      ],
      "freeze_panes": "B2",
      "note": "CapEx figures are estimates. Verify with local contractors before committing capital. Incentive values subject to tax advisor confirmation."
    },

    {
      "id": "certifications",
      "name": "Certifications",
      "order": 5,
      "type": "table",
      "description": "Green certifications relevant to this property and their penalty offset value under the applicable regulation.",
      "data_path": "certifications",
      "omit_if_empty": true,
      "columns": [
        { "header": "Certification",      "data_key": "name",               "width": 28 },
        { "header": "Status",             "data_key": "status",             "width": 18 },
        { "header": "Penalty Offset (%)", "data_key": "penalty_offset_pct", "width": 20, "format": "0%", "omit_if_all_null": true },
        { "header": "Notes",              "data_key": "description",        "width": 60, "wrap": true }
      ],
      "conditional_formatting": {
        "status": {
          "achieved":     { "fill": "#D1FAE5", "font_color": "#065F46" },
          "in-progress":  { "fill": "#DBEAFE", "font_color": "#1E40AF" },
          "recommended":  { "fill": "#F3F4F6", "font_color": "#374151" }
        }
      },
      "footer_note": "Verify penalty offset eligibility with legal counsel. Certification pathways and offset values vary by jurisdiction and may require annual renewal."
    }

  ],

  "workbook_style": {
    "header_font": "Inter",
    "body_font": "Inter",
    "header_fill_color": "brand.primary_color",
    "header_font_color": "#FFFFFF",
    "header_font_size": 9,
    "body_font_size": 9,
    "alternate_row_fill": "#F9FAFB",
    "tab_colors": {
      "Compliance Summary":    "brand.primary_color",
      "Compliance Periods":    "#DC2626",
      "Penalty Projection":    "#B91C1C",
      "Pathway to Compliance": "#15803D",
      "Certifications":        "#6B7280"
    },
    "print_settings": {
      "fit_to_page": true,
      "orientation": "landscape",
      "repeat_header_rows": 1
    }
  }
}
