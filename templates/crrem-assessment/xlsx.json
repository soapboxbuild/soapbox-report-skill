{
  "$comment": "CRREM Assessment Excel companion spec — controls exact sheet names, column order, formats, and charts for portfolio managers, fund managers, and TCFD/ISSB climate disclosure preparation. Sheets are designed to support regulatory filing and investor reporting.",

  "filename_pattern": "CRREM_{asset}_{YYYY-MM-DD}.xlsx",

  "sheets": [

    {
      "id": "assessment_summary",
      "name": "Assessment Summary",
      "order": 1,
      "type": "key_value",
      "description": "Cover-page snapshot — property, performance, and pathway status at a glance. Designed to paste into an investor report or TCFD disclosure cover page.",
      "rows": [
        { "label": "Property",                    "data_path": "property.name" },
        { "label": "Address",                     "data_path": "property.address" },
        { "label": "Asset Type",                  "data_path": "property.type" },
        { "label": "Country",                     "data_path": "property.country" },
        { "label": "GFA (m²)",                    "data_path": "property.gfa_m2",                     "format": "#,##0" },
        { "label": "Year Built",                  "data_path": "property.year_built" },
        { "label": "Report Date",                 "data_path": "report_date" },
        { "label": "Prepared By",                 "data_path": "prepared_by" },
        { "label": "Prepared For",                "data_path": "prepared_for" },
        { "label": "",                            "type": "spacer" },
        { "label": "Actual Carbon (kgCO₂/m²/yr)","data_path": "performance.actual_carbon_kgco2_m2yr", "format": "#,##0.00" },
        { "label": "Actual EUI (kWh/m²/yr)",      "data_path": "performance.actual_eui_kwh_m2yr",      "format": "#,##0.0" },
        { "label": "",                            "type": "spacer" },
        { "label": "Pathway",                     "data_path": "pathway.pathway_name" },
        { "label": "2030 Target (kgCO₂/m²/yr)",  "data_path": "pathway.target_2030",                  "format": "#,##0.00" },
        { "label": "2050 Target (kgCO₂/m²/yr)",  "data_path": "pathway.target_2050",                  "format": "#,##0.00" },
        { "label": "Current Gap vs Pathway",      "data_path": "pathway.current_gap_pct",              "format": "+0.0%;-0.0%;0.0%" },
        { "label": "Stranding Year",              "data_path": "pathway.stranding_year",               "style": "stranding_year", "omit_if_null": false },
        { "label": "",                            "type": "spacer" },
        { "label": "Electricity Factor (kgCO₂/kWh)", "data_path": "emission_factors.electricity_kgco2_kwh", "format": "#,##0.000" },
        { "label": "Gas Factor (kgCO₂/kWh)",     "data_path": "emission_factors.gas_kgco2_kwh",       "format": "#,##0.000" },
        { "label": "Emission Factor Year",        "data_path": "emission_factors.year" }
      ],
      "columns": [
        { "header": "Field",  "width": 30 },
        { "header": "Value",  "width": 56, "wrap": true }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" },
        "value_column": { "fill": "none" },
        "stranding_year_row": {
          "bold": true,
          "fill_by_value": {
            "null":    "#D1FAE5",
            "default": "#FEE2E2"
          },
          "note": "Green if null (asset is pathway-aligned with no stranding projected); red if a stranding year is present."
        }
      }
    },

    {
      "id": "pathway_table",
      "name": "Pathway Table",
      "order": 2,
      "type": "table",
      "description": "Year-by-year CRREM pathway comparison — the primary deliverable for investor reporting and regulatory disclosure. Shows where the asset stands vs. the decarbonization pathway each year.",
      "data_path": "trajectory",
      "columns": [
        { "header": "Year",                        "data_key": "year",                    "width": 10 },
        { "header": "Actual (kgCO₂/m²/yr)",        "data_key": "actual_kgco2_m2",         "width": 22, "format": "#,##0.00" },
        { "header": "Pathway Target (kgCO₂/m²/yr)","data_key": "pathway_target_kgco2_m2", "width": 28, "format": "#,##0.00" },
        { "header": "Gap (kgCO₂/m²/yr)",           "data_key": "gap_kgco2_m2",            "width": 22, "format": "+#,##0.00;-#,##0.00;0.00" },
        { "header": "% Above / Below",             "data_key": "gap_pct",                 "width": 18, "format": "+0.00%;-0.00%;0.00%", "derived": { "formula": "gap_kgco2_m2 / pathway_target_kgco2_m2" } },
        { "header": "Status",                      "data_key": "status",                  "width": 14 }
      ],
      "conditional_formatting": {
        "status": {
          "aligned":  { "fill": "#D1FAE5", "font_color": "#065F46" },
          "at-risk":  { "fill": "#FEF3C7", "font_color": "#92400E" },
          "stranded": { "fill": "#FEE2E2", "font_color": "#991B1B" }
        }
      },
      "charts": [
        {
          "id": "crrem_stranding_chart",
          "type": "LineChart",
          "title": "CRREM Carbon Pathway — Stranding Analysis",
          "x_axis": "year",
          "series": [
            { "data_key": "actual_kgco2_m2",        "label": "Actual / Projected",    "color": "#EF4444" },
            { "data_key": "pathway_target_kgco2_m2", "label": "CRREM Pathway Target", "color": "#10B981", "line_style": "dashed" }
          ],
          "y_axis_label": "kgCO₂/m²/yr",
          "x_axis_label": "Year",
          "reference_annotation": {
            "type": "vertical_line_on_value",
            "data_key": "status",
            "trigger_value": "stranded",
            "label": "Stranding",
            "color": "#EF4444",
            "line_style": "dotted"
          },
          "placement": "right_of_table",
          "width_cols": 11,
          "height_rows": 22,
          "note": "Stranding occurs where the Actual line crosses above the Pathway Target line. This chart is the primary deliverable for TCFD/ISSB investor reporting."
        }
      ],
      "freeze_panes": "B2"
    },

    {
      "id": "fuel_mix",
      "name": "Fuel Mix",
      "order": 3,
      "type": "key_value",
      "description": "Energy fuel mix breakdown and emission factors — supports model assumptions for utility expense and carbon intensity calculation.",
      "rows": [
        { "label": "Electricity (%)",            "data_path": "performance.fuel_mix.electricity_pct", "format": "0%" },
        { "label": "Gas (%)",                    "data_path": "performance.fuel_mix.gas_pct",         "format": "0%" },
        { "label": "Other (%)",                  "data_path": "performance.fuel_mix.other_pct",       "format": "0%" },
        { "label": "",                           "type": "spacer" },
        { "label": "Electricity Factor (kgCO₂/kWh)", "data_path": "emission_factors.electricity_kgco2_kwh", "format": "#,##0.000" },
        { "label": "Gas Factor (kgCO₂/kWh)",    "data_path": "emission_factors.gas_kgco2_kwh",       "format": "#,##0.000" },
        { "label": "Other Factor (kgCO₂/kWh)",  "data_path": "emission_factors.other_kgco2_kwh",     "format": "#,##0.000", "omit_if_null": true },
        { "label": "Factor Source Year",         "data_path": "emission_factors.year" },
        { "label": "Factor Source",              "data_path": "emission_factors.source",              "omit_if_null": true }
      ],
      "columns": [
        { "header": "Category", "width": 30 },
        { "header": "Value",    "width": 48, "wrap": true }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" }
      },
      "footer_note": "Fuel mix percentages must sum to 100%. Emission factors are sourced from the reference year above — verify against the latest published grid factors for final regulatory filings."
    },

    {
      "id": "recommendations",
      "name": "Recommendations",
      "order": 4,
      "type": "table",
      "description": "Ranked decarbonization recommendations — supports asset management action planning and ESG reporting.",
      "data_path": "recommendations",
      "columns": [
        { "header": "Rank",                  "data_key": "rank",                 "width": 8 },
        { "header": "Priority",              "data_key": "priority",             "width": 14 },
        { "header": "Title",                 "data_key": "title",                "width": 28 },
        { "header": "Action",                "data_key": "action",               "width": 56, "wrap": true },
        { "header": "CO₂ Reduction (%)",     "data_key": "carbon_reduction_pct", "width": 18, "format": "0.0%" },
        { "header": "CapEx Range",           "data_key": "capex_range",          "width": 20 },
        { "header": "Timeline",              "data_key": "timeline",             "width": 16, "omit_if_all_null": true }
      ],
      "conditional_formatting": {
        "priority": {
          "immediate":  { "fill": "#FEE2E2", "font_color": "#991B1B" },
          "near-term":  { "fill": "#FEF3C7", "font_color": "#92400E" },
          "long-term":  { "fill": "#DBEAFE", "font_color": "#1E40AF" }
        }
      },
      "row_height": 50,
      "freeze_panes": "B2"
    },

    {
      "id": "tcfd_context",
      "name": "TCFD Context",
      "order": 5,
      "type": "key_value",
      "description": "TCFD / ISSB S2 climate risk context — physical risk, transition risk, scenario analysis, and governance notes. Omitted from workbook if tcfd_context is absent in the data.",
      "omit_if_path_absent": "tcfd_context",
      "header_note": "For ISSB S2 / TCFD disclosure — quantified financial impacts are required for mandatory jurisdictions (e.g. UK, EU, New Zealand). Supplement with adviser-prepared financial impact estimates before filing.",
      "rows": [
        { "label": "Physical Risk Score",        "data_path": "tcfd_context.physical_risk_score",    "style": "risk_score" },
        { "label": "Transition Risk Level",      "data_path": "tcfd_context.transition_risk_level",  "style": "transition_risk" },
        { "label": "",                           "type": "spacer" },
        { "label": "Scenario: 1.5°C Impact",     "data_path": "tcfd_context.scenario_1_5c_impact",   "style": "wrap", "row_height": 60 },
        { "label": "Scenario: 2°C Impact",       "data_path": "tcfd_context.scenario_2c_impact",     "style": "wrap", "row_height": 60 },
        { "label": "",                           "type": "spacer" },
        { "label": "Governance Notes",           "data_path": "tcfd_context.governance_notes",       "style": "wrap", "row_height": 80 }
      ],
      "columns": [
        { "header": "Field",  "width": 28 },
        { "header": "Value",  "width": 72, "wrap": true }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" },
        "risk_score_row": {
          "bold": true,
          "fill_by_value": {
            "Low":       "#D1FAE5",
            "Medium":    "#FFFBEB",
            "High":      "#FEE2E2",
            "Very High": "#FCA5A5"
          }
        },
        "transition_risk_row": {
          "bold": true,
          "fill_by_value": {
            "Low":       "#D1FAE5",
            "Medium":    "#FFFBEB",
            "High":      "#FEE2E2",
            "Very High": "#FCA5A5"
          }
        }
      }
    }

  ],

  "workbook_style": {
    "header_font": "Inter",
    "body_font": "Inter",
    "header_fill_color": "brand.primary_color",
    "header_font_color": "#FFFFFF",
    "header_font_size": 9,
    "body_font_size": 9,
    "alternate_row_fill": "#F9FAFB",
    "tab_colors": {
      "Assessment Summary": "brand.primary_color",
      "Pathway Table":      "brand.highlight_color",
      "Fuel Mix":           "brand.secondary_color",
      "Recommendations":    "#3B82F6",
      "TCFD Context":       "#6B7280"
    },
    "print_settings": {
      "fit_to_page": true,
      "orientation": "landscape",
      "repeat_header_rows": 1
    }
  }
}
