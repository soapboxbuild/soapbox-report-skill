{
  "$comment": "Portfolio ESG Summary Excel companion spec — controls sheet names, column order, formats, and charts for LP reporting, GRESB submissions, and board ESG updates. Audience: CFOs, LPs, ESG committees. Designed for roll-ups and portfolio-level calculations.",

  "filename_pattern": "Portfolio_ESG_{portfolio}_{YYYY-MM-DD}.xlsx",

  "sheets": [

    {
      "id": "portfolio_overview",
      "name": "Portfolio Overview",
      "order": 1,
      "type": "key_value",
      "description": "Cover-page summary of portfolio identity, emissions totals, and target progress. Designed for LP cover pages and board ESG decks.",
      "rows": [
        { "label": "Portfolio",              "data_path": "portfolio.name" },
        { "label": "Fund Name",              "data_path": "portfolio.fund_name",      "omit_if_null": true },
        { "label": "Vintage Year",           "data_path": "portfolio.vintage_year",   "omit_if_null": true },
        { "label": "Total Assets",           "data_path": "portfolio.total_assets" },
        { "label": "Total GFA (sqft)",       "data_path": "portfolio.total_gfa_sqft", "format": "#,##0" },
        { "label": "Total AUM",              "data_path": "portfolio.total_aum_usd",  "format": "$#,##0", "omit_if_null": true },
        { "label": "Reporting Year",         "data_path": "portfolio.reporting_year" },
        { "label": "",                       "type": "spacer" },
        { "label": "Scope 1 (tCO₂e)",   "data_path": "emissions_summary.total_scope1_tco2e",          "format": "#,##0.0" },
        { "label": "Scope 2 (tCO₂e)",   "data_path": "emissions_summary.total_scope2_tco2e",          "format": "#,##0.0" },
        { "label": "Scope 3 (tCO₂e)",   "data_path": "emissions_summary.total_scope3_tco2e",          "format": "#,##0.0", "omit_if_null": true },
        { "label": "Portfolio Intensity",    "data_path": "emissions_summary.portfolio_intensity_kgco2_m2yr", "format": "#,##0.0" },
        { "label": "YoY Change",             "data_path": "emissions_summary.yoy_change_pct",           "format": "0.0%",   "omit_if_null": true },
        { "label": "Data Coverage",          "data_path": "emissions_summary.data_coverage_pct",        "format": "0%" },
        { "label": "Verification Status",    "data_path": "emissions_summary.verification_status" },
        { "label": "",                       "type": "spacer" },
        { "label": "Baseline Year",          "data_path": "targets.baseline_year" },
        { "label": "Baseline Intensity",     "data_path": "targets.baseline_intensity",            "format": "#,##0.0" },
        { "label": "2030 Reduction Target",  "data_path": "targets.target_2030_pct_reduction",    "format": "0%" },
        { "label": "2050 Net Zero",          "data_path": "targets.target_2050_net_zero" },
        { "label": "Current Progress",       "data_path": "targets.current_progress_pct",          "format": "0.0%", "style": "progress_pct" },
        { "label": "",                       "type": "spacer" },
        { "label": "Report Date",            "data_path": "report_date" },
        { "label": "Prepared By",            "data_path": "prepared_by" },
        { "label": "Prepared For",           "data_path": "prepared_for" }
      ],
      "columns": [
        { "header": "Field",  "width": 28 },
        { "header": "Value",  "width": 64, "wrap": true }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" },
        "value_column": { "fill": "none" },
        "progress_pct_row": {
          "bold": true,
          "fill_by_threshold": {
            "green":  { "min": 0.75, "fill": "#D1FAE5", "font_color": "#065F46" },
            "amber":  { "min": 0.40, "fill": "#FFFBEB", "font_color": "#92400E" },
            "red":    { "min": 0,    "fill": "#FEE2E2", "font_color": "#991B1B" }
          },
          "note": "Green ≥ 75% of 2030 target; amber 40-74%; red < 40%."
        }
      }
    },

    {
      "id": "asset_inventory",
      "name": "Asset Inventory",
      "order": 2,
      "type": "table",
      "description": "Asset-level emissions and risk profile. Sorted by intensity descending — highest emitters at top. Designed as the portfolio heat map for fund managers.",
      "data_path": "assets",
      "columns": [
        { "header": "Asset Name",               "data_key": "name",                  "width": 30 },
        { "header": "Type",                     "data_key": "type",                  "width": 16 },
        { "header": "Location",                 "data_key": "location",              "width": 22 },
        { "header": "GFA (sqft)",               "data_key": "gfa_sqft",              "width": 14, "format": "#,##0" },
        { "header": "Scope 1 (tCO₂e)",     "data_key": "scope1",                "width": 18, "format": "#,##0.0" },
        { "header": "Scope 2 (tCO₂e)",     "data_key": "scope2",                "width": 18, "format": "#,##0.0" },
        { "header": "EUI (kWh/m²)",         "data_key": "eui_kwh_m2",            "width": 14, "format": "#,##0.0", "omit_if_all_null": true },
        { "header": "Intensity (kgCO₂/m²)", "data_key": "intensity_kgco2_m2yr",  "width": 22, "format": "#,##0.0" },
        { "header": "CRREM Status",             "data_key": "crrem_status",          "width": 16 },
        { "header": "BPS Exposure",             "data_key": "bps_exposure",          "width": 16 },
        { "header": "Data Quality (1-5)",       "data_key": "data_quality",          "width": 18 }
      ],
      "sort": {
        "column": "intensity_kgco2_m2yr",
        "direction": "descending"
      },
      "conditional_formatting": {
        "crrem_status": {
          "aligned":  { "fill": "#D1FAE5", "font_color": "#065F46" },
          "at-risk":  { "fill": "#FFFBEB", "font_color": "#92400E" },
          "stranded": { "fill": "#FEE2E2", "font_color": "#991B1B" }
        },
        "bps_exposure": {
          "none":   { "fill": "#D1FAE5", "font_color": "#065F46" },
          "low":    { "fill": "#ECFDF5", "font_color": "#065F46" },
          "medium": { "fill": "#FFFBEB", "font_color": "#92400E" },
          "high":   { "fill": "#FEE2E2", "font_color": "#991B1B" }
        },
        "intensity_kgco2_m2yr": {
          "rule": "gradient",
          "min_color": "#D1FAE5",
          "max_color": "#FCA5A5",
          "note": "Green to red gradient — highlights the highest-emitting assets at a glance."
        }
      },
      "charts": [
        {
          "id": "intensity_by_asset",
          "type": "BarChart",
          "title": "Carbon Intensity by Asset (kgCO₂/m²/yr)",
          "x_axis": "name",
          "y_axis": "intensity_kgco2_m2yr",
          "sort": "descending",
          "y_axis_label": "Intensity (kgCO₂/m²/yr)",
          "series_color": "#DC2626",
          "placement": "below_table",
          "width_cols": 20,
          "height_rows": 18,
          "note": "Portfolio heat map — sorted highest to lowest intensity. Use to identify priority assets for capital allocation."
        }
      ],
      "freeze_panes": "B2",
      "note": "Emission figures are market-based Scope 2 where available. Data quality scores reflect confidence in underlying consumption data: 5 = verified metered, 1 = rough estimate."
    },

    {
      "id": "emissions_by_scope",
      "name": "Emissions by Scope",
      "order": 3,
      "type": "key_value",
      "description": "Portfolio-level Scope 1/2/3 breakdown with percentage composition. Supports GHG inventory disclosure for GRESB, PRI, and TCFD reporting.",
      "rows": [
        { "label": "Scope 1 (tCO₂e)",    "data_path": "emissions_summary.total_scope1_tco2e",          "format": "#,##0.0" },
        { "label": "Scope 2 (tCO₂e)",    "data_path": "emissions_summary.total_scope2_tco2e",          "format": "#,##0.0" },
        { "label": "Scope 3 (tCO₂e)",    "data_path": "emissions_summary.total_scope3_tco2e",          "format": "#,##0.0", "omit_if_null": true },
        { "label": "",                    "type": "spacer" },
        { "label": "Scope 1 Share (%)",   "data_path": "_computed.scope1_share_pct",                    "format": "0.0%", "compute": "total_scope1_tco2e / (total_scope1_tco2e + total_scope2_tco2e + total_scope3_tco2e)" },
        { "label": "Scope 2 Share (%)",   "data_path": "_computed.scope2_share_pct",                    "format": "0.0%", "compute": "total_scope2_tco2e / (total_scope1_tco2e + total_scope2_tco2e + total_scope3_tco2e)" },
        { "label": "Scope 3 Share (%)",   "data_path": "_computed.scope3_share_pct",                    "format": "0.0%", "compute": "total_scope3_tco2e / (total_scope1_tco2e + total_scope2_tco2e + total_scope3_tco2e)", "omit_if_null": true },
        { "label": "",                    "type": "spacer" },
        { "label": "Portfolio Intensity", "data_path": "emissions_summary.portfolio_intensity_kgco2_m2yr", "format": "#,##0.0" },
        { "label": "YoY Change",          "data_path": "emissions_summary.yoy_change_pct",               "format": "0.0%", "omit_if_null": true },
        { "label": "Data Coverage",       "data_path": "emissions_summary.data_coverage_pct",            "format": "0%" },
        { "label": "Verification Status", "data_path": "emissions_summary.verification_status" }
      ],
      "columns": [
        { "header": "Metric", "width": 28 },
        { "header": "Value",  "width": 32, "wrap": true }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" }
      },
      "charts": [
        {
          "id": "scope_pie",
          "type": "PieChart",
          "title": "Emissions by Scope",
          "slices": [
            { "label": "Scope 1", "data_path": "emissions_summary.total_scope1_tco2e", "color": "#1D4ED8" },
            { "label": "Scope 2", "data_path": "emissions_summary.total_scope2_tco2e", "color": "#60A5FA" },
            { "label": "Scope 3", "data_path": "emissions_summary.total_scope3_tco2e", "color": "#BFDBFE", "omit_if_null": true }
          ],
          "show_labels": true,
          "show_legend": true,
          "placement": "right_of_table",
          "width_cols": 8,
          "height_rows": 14
        },
        {
          "id": "yoy_comparison",
          "type": "BarChart",
          "title": "Year-over-Year Emissions Comparison",
          "series": [
            { "label": "Prior Year", "data_path": "_computed.prior_year_total_tco2e", "color": "#9CA3AF" },
            { "label": "Current Year", "data_path": "_computed.current_year_total_tco2e", "color": "#1D4ED8" }
          ],
          "y_axis_label": "Total Emissions (tCO₂e)",
          "placement": "below_pie_chart",
          "width_cols": 8,
          "height_rows": 14,
          "omit_if_null": "emissions_summary.yoy_change_pct",
          "note": "Omitted if prior year data is not available."
        }
      ]
    },

    {
      "id": "initiatives",
      "name": "Initiatives",
      "order": 4,
      "type": "table",
      "description": "Portfolio-level carbon reduction initiatives showing status, coverage, and projected impact. Supports ESG committee and LP reporting.",
      "data_path": "initiatives",
      "omit_if_empty": true,
      "columns": [
        { "header": "Initiative",                    "data_key": "name",                      "width": 36, "wrap": true },
        { "header": "Status",                        "data_key": "status",                    "width": 16 },
        { "header": "Assets Covered",                "data_key": "assets_covered",            "width": 16 },
        { "header": "Projected Reduction (tCO₂e)", "data_key": "projected_reduction_tco2e", "width": 26, "format": "#,##0.0" },
        { "header": "Total CapEx ($)",               "data_key": "capex_total_usd",           "width": 18, "format": "$#,##0" },
        { "header": "% of Portfolio Covered",        "data_key": "_computed_pct_coverage",    "width": 22, "format": "0%", "compute": "assets_covered / portfolio.total_assets" }
      ],
      "totals_row": {
        "label_column": "name",
        "label": "TOTAL",
        "sum_columns": ["projected_reduction_tco2e", "capex_total_usd"],
        "format_by_column": {
          "projected_reduction_tco2e": "#,##0.0",
          "capex_total_usd": "$#,##0"
        },
        "bold": true,
        "fill": "primary"
      },
      "conditional_formatting": {
        "status": {
          "complete":    { "fill": "#D1FAE5", "font_color": "#065F46" },
          "in-progress": { "fill": "#DBEAFE", "font_color": "#1E40AF" },
          "planned":     { "fill": "#F3F4F6", "font_color": "#374151" }
        }
      },
      "charts": [
        {
          "id": "reduction_by_initiative",
          "type": "BarChart",
          "title": "Projected Reduction by Initiative (tCO₂e/yr)",
          "x_axis": "name",
          "y_axis": "projected_reduction_tco2e",
          "sort": "descending",
          "y_axis_label": "Projected Reduction (tCO₂e/yr)",
          "series_color": "#15803D",
          "placement": "right_of_table",
          "width_cols": 10,
          "height_rows": 18
        }
      ],
      "freeze_panes": "B2"
    },

    {
      "id": "progress_to_target",
      "name": "Progress to Target",
      "order": 5,
      "type": "key_value",
      "description": "Target tracker showing baseline, current position, 2030 goal, and projected 2030 outcome if all initiatives complete. Designed for investor ESG reporting.",
      "rows": [
        { "label": "Baseline Year",                "data_path": "targets.baseline_year" },
        { "label": "Baseline Intensity",           "data_path": "targets.baseline_intensity",           "format": "#,##0.0" },
        { "label": "",                             "type": "spacer" },
        { "label": "2030 Reduction Target",        "data_path": "targets.target_2030_pct_reduction",    "format": "0%" },
        { "label": "2050 Net Zero Commitment",     "data_path": "targets.target_2050_net_zero" },
        { "label": "",                             "type": "spacer" },
        { "label": "Current Intensity",            "data_path": "emissions_summary.portfolio_intensity_kgco2_m2yr", "format": "#,##0.0" },
        { "label": "Current Progress",             "data_path": "targets.current_progress_pct",         "format": "0.0%", "style": "progress_pct" },
        { "label": "",                             "type": "spacer" },
        { "label": "Projected 2030 Intensity",     "data_path": "_computed.projected_2030_intensity",   "format": "#,##0.0", "omit_if_null": true, "note": "If all active and planned initiatives complete on schedule." },
        { "label": "On Track (2030 Target)",       "data_path": "_computed.on_track",                   "style": "on_track", "omit_if_null": true }
      ],
      "columns": [
        { "header": "Metric", "width": 32 },
        { "header": "Value",  "width": 48, "wrap": true }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" },
        "progress_pct_row": {
          "bold": true,
          "fill_by_threshold": {
            "green":  { "min": 0.75, "fill": "#D1FAE5", "font_color": "#065F46" },
            "amber":  { "min": 0.40, "fill": "#FFFBEB", "font_color": "#92400E" },
            "red":    { "min": 0,    "fill": "#FEE2E2", "font_color": "#991B1B" }
          }
        },
        "on_track_row": {
          "bold": true,
          "fill_by_value": {
            "Yes": "#D1FAE5",
            "No":  "#FEE2E2"
          }
        }
      }
    },

    {
      "id": "gresb",
      "name": "GRESB",
      "order": 6,
      "type": "key_value",
      "description": "GRESB benchmark scorecard. Omitted from workbook if no GRESB submission exists for this reporting year.",
      "omit_if_null": "gresb_context",
      "rows": [
        { "label": "GRESB Score",           "data_path": "gresb_context.score",               "style": "gresb_score" },
        { "label": "Peer Average",          "data_path": "gresb_context.peer_average" },
        { "label": "Delta vs Peers",        "data_path": "_computed.gresb_delta",             "compute": "gresb_context.score - gresb_context.peer_average", "format": "+0;-0;0", "style": "gresb_delta" },
        { "label": "",                      "type": "spacer" },
        { "label": "Green Star Rating",     "data_path": "gresb_context.green_star_rating",   "omit_if_null": true },
        { "label": "Data Coverage Score",   "data_path": "gresb_context.data_coverage_score", "omit_if_null": true }
      ],
      "columns": [
        { "header": "Metric", "width": 28 },
        { "header": "Value",  "width": 32 }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" },
        "gresb_score_row": {
          "bold": true,
          "font_size": 14,
          "fill": "accent"
        },
        "gresb_delta_row": {
          "bold": true,
          "fill_by_threshold": {
            "green": { "min": 1,    "fill": "#D1FAE5", "font_color": "#065F46" },
            "amber": { "min": -4,   "fill": "#FFFBEB", "font_color": "#92400E" },
            "red":   { "min": -999, "fill": "#FEE2E2", "font_color": "#991B1B" }
          },
          "note": "Green if score above peer average; amber if within 4 points below; red if more than 4 points below."
        }
      }
    }

  ],

  "workbook_style": {
    "header_font": "Inter",
    "body_font": "Inter",
    "header_fill_color": "brand.primary_color",
    "header_font_color": "#FFFFFF",
    "header_font_size": 9,
    "body_font_size": 9,
    "alternate_row_fill": "#F9FAFB",
    "tab_colors": {
      "Portfolio Overview":  "brand.primary_color",
      "Asset Inventory":     "brand.highlight_color",
      "Emissions by Scope":  "brand.secondary_color",
      "Initiatives":         "#15803D",
      "Progress to Target":  "#1D4ED8",
      "GRESB":               "#6B7280"
    },
    "print_settings": {
      "fit_to_page": true,
      "orientation": "landscape",
      "repeat_header_rows": 1
    }
  }
}
