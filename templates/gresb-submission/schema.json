{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GRESB Assessment Preparation Report",
  "description": "Data schema for the gresb-submission report template",
  "type": "object",
  "required": ["entity", "scores", "pillars", "data_coverage", "performance_data", "prepared_by", "prepared_for", "report_date"],
  "properties": {
    "entity": {
      "type": "object",
      "required": ["name", "reporting_year", "assessment_type"],
      "properties": {
        "name":             { "type": "string", "description": "Entity / portfolio name" },
        "reporting_year":   { "type": "integer", "description": "Assessment year (e.g. 2025)" },
        "assessment_type":  { "type": "string", "enum": ["real-estate", "infrastructure"], "description": "GRESB assessment track" },
        "portfolio_gfa_sqft": { "type": "number", "description": "Total portfolio GFA in square feet" },
        "total_assets":     { "type": "integer", "description": "Total number of assets in the portfolio" }
      }
    },
    "scores": {
      "type": "object",
      "required": ["overall_score", "peer_average", "management_score", "performance_score"],
      "properties": {
        "overall_score":      { "type": "number", "minimum": 0, "maximum": 100, "description": "Total GRESB score (0–100)" },
        "peer_average":       { "type": "number", "minimum": 0, "maximum": 100, "description": "Peer group average score" },
        "management_score":   { "type": "number", "minimum": 0, "maximum": 35, "description": "Management pillar score (max 35)" },
        "performance_score":  { "type": "number", "minimum": 0, "maximum": 65, "description": "Performance pillar score (max 65)" },
        "green_star_rating":  {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 5 },
            { "type": "string", "enum": ["None"] }
          ],
          "description": "GRESB Green Star rating (1–5 or 'None')"
        },
        "prior_year_score":   { "type": "number", "minimum": 0, "maximum": 100, "description": "Prior year overall score (optional)" },
        "yoy_change":         { "type": "number", "description": "Year-over-year score change (+/-)" }
      }
    },
    "pillars": {
      "type": "object",
      "required": ["management", "performance"],
      "properties": {
        "management": {
          "type": "object",
          "required": ["leadership_pts", "policies_pts", "reporting_pts", "risk_pts", "max_pts"],
          "properties": {
            "leadership_pts":  { "type": "number", "description": "Leadership & Governance points earned" },
            "policies_pts":    { "type": "number", "description": "Policies & Disclosure points earned" },
            "reporting_pts":   { "type": "number", "description": "Reporting points earned" },
            "risk_pts":        { "type": "number", "description": "Risk Management points earned" },
            "max_pts":         { "type": "number", "enum": [35], "description": "Maximum management pillar points" }
          }
        },
        "performance": {
          "type": "object",
          "required": ["energy_pts", "ghg_pts", "water_pts", "waste_pts", "certifications_pts", "max_pts"],
          "properties": {
            "energy_pts":          { "type": "number", "description": "Energy points earned" },
            "ghg_pts":             { "type": "number", "description": "GHG emissions points earned" },
            "water_pts":           { "type": "number", "description": "Water points earned" },
            "waste_pts":           { "type": "number", "description": "Waste points earned" },
            "certifications_pts":  { "type": "number", "description": "Building certifications points earned" },
            "max_pts":             { "type": "number", "enum": [65], "description": "Maximum performance pillar points" }
          }
        }
      }
    },
    "data_coverage": {
      "type": "object",
      "required": ["covered_gfa_sqft", "total_gfa_sqft", "coverage_pct", "verified_pct"],
      "properties": {
        "covered_gfa_sqft":   { "type": "number", "description": "GFA with data coverage (sqft)" },
        "total_gfa_sqft":     { "type": "number", "description": "Total portfolio GFA (sqft)" },
        "coverage_pct":       { "type": "number", "minimum": 0, "maximum": 100, "description": "Data coverage percentage" },
        "verified_pct":       { "type": "number", "minimum": 0, "maximum": 100, "description": "Percentage of data verified/assured" },
        "assurance_provider": { "type": "string", "description": "Third-party assurance provider name (optional)" }
      }
    },
    "performance_data": {
      "type": "object",
      "required": ["energy_consumption_mwh", "energy_intensity_kwh_m2", "ghg_scope1_tco2e", "ghg_scope2_tco2e", "water_m3", "waste_tonnes", "waste_recycling_pct"],
      "properties": {
        "energy_consumption_mwh":   { "type": "number", "description": "Total energy consumption in MWh" },
        "energy_intensity_kwh_m2":  { "type": "number", "description": "Energy use intensity in kWh/m²" },
        "ghg_scope1_tco2e":         { "type": "number", "description": "Scope 1 GHG emissions in tCO2e" },
        "ghg_scope2_tco2e":         { "type": "number", "description": "Scope 2 GHG emissions in tCO2e" },
        "water_m3":                 { "type": "number", "description": "Water consumption in m³" },
        "waste_tonnes":             { "type": "number", "description": "Total waste generated in tonnes" },
        "waste_recycling_pct":      { "type": "number", "minimum": 0, "maximum": 100, "description": "Waste recycling rate (%)" }
      }
    },
    "improvement_opportunities": {
      "type": "array",
      "description": "Ranked list of actions to improve GRESB score",
      "items": {
        "type": "object",
        "required": ["pillar", "action", "estimated_points_uplift", "effort", "timeline_months"],
        "properties": {
          "pillar":                    { "type": "string", "enum": ["management", "performance"], "description": "Which GRESB pillar this action affects" },
          "action":                    { "type": "string", "description": "Description of the recommended action" },
          "estimated_points_uplift":   { "type": "number", "description": "Estimated points gain" },
          "effort":                    { "type": "string", "enum": ["low", "medium", "high"], "description": "Implementation effort level" },
          "timeline_months":           { "type": "integer", "description": "Estimated time to implement in months" }
        }
      }
    },
    "certifications": {
      "type": "array",
      "description": "Building certification summary",
      "items": {
        "type": "object",
        "required": ["name", "certified_assets", "total_assets", "certified_gfa_pct"],
        "properties": {
          "name":              { "type": "string", "enum": ["LEED", "BREEAM", "ENERGY STAR", "NABERS"], "description": "Certification program name" },
          "certified_assets":  { "type": "integer", "description": "Number of certified assets" },
          "total_assets":      { "type": "integer", "description": "Total assets eligible for this certification" },
          "certified_gfa_pct": { "type": "number", "minimum": 0, "maximum": 100, "description": "Certified GFA as % of total portfolio GFA" }
        }
      }
    },
    "prepared_by":         { "type": "string", "description": "Name of the person or organization preparing this report" },
    "prepared_for":        { "type": "string", "description": "Name of the intended recipient / fund / entity" },
    "report_date":         { "type": "string", "format": "date", "description": "Report preparation date (YYYY-MM-DD)" },
    "submission_deadline": { "type": "string", "format": "date", "description": "GRESB submission portal deadline (YYYY-MM-DD)" }
  }
}
