{
  "$comment": "Decarb Roadmap Excel companion spec — financial model companion for asset-level decarbonization plans. Structured for lender diligence and green financing applications (PACE, green loans, Fannie Mae Green Rewards). Migrated from Audette.",

  "filename_pattern": "DecarbRoadmap_{building}_{YYYY-MM-DD}.xlsx",

  "sheets": [

    {
      "id": "roadmap_summary",
      "name": "Roadmap Summary",
      "order": 1,
      "type": "key_value",
      "description": "Cover-page snapshot — building profile and plan financials in a single view. Designed to paste into a lender package or investment committee memo.",
      "rows": [
        { "label": "Building Name",        "data_path": "building.name" },
        { "label": "Address",              "data_path": "building.address" },
        { "label": "Building Type",        "data_path": "building.type" },
        { "label": "GFA (sqft)",           "data_path": "building.gfa_sqft",                  "format": "#,##0", "omit_if_null": true },
        { "label": "Year Built",           "data_path": "building.year_built",                "omit_if_null": true },
        { "label": "Baseline EUI",         "data_path": "building.baseline_eui_kbtu_sqft",    "format": "#,##0.0", "unit": "kBtu/sqft/yr", "omit_if_null": true },
        { "label": "Baseline Emissions",   "data_path": "building.baseline_emissions_tco2e",  "format": "#,##0.0", "unit": "tCO₂e/yr" },
        { "label": "Baseline Energy Cost", "data_path": "building.baseline_cost_usd",         "format": "$#,##0",  "omit_if_null": true },
        { "label": "",                     "type": "spacer" },
        { "label": "Total CapEx",          "data_path": "plan_summary.total_capex",                "format": "$#,##0" },
        { "label": "Annual Savings",       "data_path": "plan_summary.total_annual_savings",       "format": "$#,##0" },
        { "label": "NPV",                  "data_path": "plan_summary.npv",                        "format": "$#,##0", "omit_if_null": true },
        { "label": "IRR",                  "data_path": "plan_summary.irr",                        "format": "0.0%",  "omit_if_null": true },
        { "label": "Simple Payback",       "data_path": "plan_summary.simple_payback_years",       "format": "#,##0.0", "unit": "years" },
        { "label": "Total Carbon Reduction","data_path": "plan_summary.total_carbon_reduction_tco2e","format": "#,##0.0", "unit": "tCO₂e" },
        { "label": "Net-Zero Year",        "data_path": "plan_summary.net_zero_year",              "omit_if_null": true },
        { "label": "",                     "type": "spacer" },
        { "label": "Prepared By",          "data_path": "prepared_by" },
        { "label": "Prepared For",         "data_path": "prepared_for" },
        { "label": "Report Date",          "data_path": "report_date" }
      ],
      "columns": [
        { "header": "Field",  "width": 26 },
        { "header": "Value",  "width": 48, "wrap": true }
      ],
      "style": {
        "label_column": { "bold": true, "fill": "accent" },
        "value_column": { "fill": "none" }
      }
    },

    {
      "id": "measures",
      "name": "Measures",
      "order": 2,
      "type": "table",
      "description": "Individual carbon reduction measures — core of the decarbonization plan. Sorted by implementation year. Includes CapEx, savings, payback, and carbon impact per measure.",
      "data_path": "measures",
      "columns": [
        { "header": "Measure",                 "data_key": "name",                   "width": 40, "wrap": true },
        { "header": "Category",                "data_key": "category",               "width": 16 },
        { "header": "Implementation Year",     "data_key": "implementation_year",    "width": 20, "format": "#,##0" },
        { "header": "CapEx ($)",               "data_key": "capex",                  "width": 16, "format": "$#,##0" },
        { "header": "Annual Savings ($)",      "data_key": "annual_savings_usd",     "width": 18, "format": "$#,##0" },
        { "header": "Payback (yrs)",           "data_key": "payback_years",          "width": 14, "format": "#,##0.0" },
        { "header": "CO₂ Reduction (tCO₂e)",  "data_key": "carbon_reduction_tco2e", "width": 22, "format": "#,##0.0" }
      ],
      "sort": { "column": "implementation_year", "direction": "ascending" },
      "totals_row": {
        "label_column": "name",
        "label": "TOTAL",
        "sum_columns": ["capex", "annual_savings_usd", "carbon_reduction_tco2e"],
        "format_by_column": {
          "capex":                  "$#,##0",
          "annual_savings_usd":     "$#,##0",
          "carbon_reduction_tco2e": "#,##0.0"
        },
        "bold": true,
        "fill": "primary"
      },
      "conditional_formatting": {
        "category": {
          "lighting":    { "fill": "#FEF3C7", "font_color": "#92400E" },
          "hvac":        { "fill": "#DBEAFE", "font_color": "#1E40AF" },
          "envelope":    { "fill": "#F3F4F6", "font_color": "#374151" },
          "renewables":  { "fill": "#D1FAE5", "font_color": "#065F46" },
          "controls":    { "fill": "#EDE9FE", "font_color": "#5B21B6" },
          "dhw":         { "fill": "#FEE2E2", "font_color": "#991B1B" },
          "ev-charging": { "fill": "#ECFDF5", "font_color": "#065F46" },
          "other":       { "fill": "#F9FAFB", "font_color": "#6B7280" }
        }
      },
      "charts": [
        {
          "id": "carbon_reduction_by_measure",
          "type": "BarChart",
          "title": "CO₂ Reduction by Measure",
          "x_axis": "name",
          "y_axis": "carbon_reduction_tco2e",
          "aggregate": "none",
          "sort": "descending",
          "y_axis_label": "tCO₂e / yr",
          "series_color": "primary",
          "placement": "below_table",
          "width_cols": 16,
          "height_rows": 16
        },
        {
          "id": "capex_by_category",
          "type": "BarChart",
          "title": "CapEx by Category",
          "x_axis": "category",
          "y_axis": "capex",
          "aggregate": "sum",
          "group": "clustered",
          "y_axis_label": "CapEx ($)",
          "series_color": "highlight",
          "placement": "right_of_table",
          "width_cols": 9,
          "height_rows": 16
        }
      ],
      "freeze_panes": "C2",
      "note": "CapEx and savings figures are model-based estimates. Verify with contractors and energy engineers before committing capital."
    },

    {
      "id": "financial_projection",
      "name": "Financial Projection",
      "order": 3,
      "type": "table",
      "description": "Year-by-year cumulative cash flow — the core financial model for green loan and PACE underwriting. Breakeven year is highlighted. Critical deliverable for lender diligence packages.",
      "data_path": "financial_projection",
      "columns": [
        { "header": "Year",                 "data_key": "year",           "width": 10, "format": "#,##0" },
        { "header": "CapEx Spent ($)",      "data_key": "capex_spent",    "width": 18, "format": "$#,##0" },
        { "header": "Annual Savings ($)",   "data_key": "annual_savings", "width": 18, "format": "$#,##0" },
        { "header": "Cumulative Net ($)",   "data_key": "cumulative_net", "width": 20, "format": "$#,##0" }
      ],
      "conditional_formatting": {
        "cumulative_net": [
          { "condition": "< 0",  "fill": "#FEE2E2", "font_color": "#991B1B" },
          { "condition": ">= 0", "fill": "#D1FAE5", "font_color": "#065F46" }
        ]
      },
      "row_overrides": [
        {
          "match": "breakeven_year",
          "detection": "first row where cumulative_net >= 0",
          "style": { "bold": true, "fill": "#ECFDF5", "border_top": "medium" }
        }
      ],
      "charts": [
        {
          "id": "cumulative_net_over_time",
          "type": "LineChart",
          "title": "Cumulative Net Cash Flow",
          "x_axis": "year",
          "series": [
            { "label": "Cumulative Net ($)", "data_key": "cumulative_net", "color": "primary" }
          ],
          "y_axis_label": "Cumulative Net ($)",
          "zero_line": true,
          "placement": "right_of_table",
          "width_cols": 10,
          "height_rows": 18
        }
      ],
      "freeze_panes": "B2",
      "note": "Cumulative Net = sum of Annual Savings minus sum of CapEx Spent to date. Red = unrecovered investment. Bold row = breakeven. This chart is suitable for direct inclusion in green financing applications."
    },

    {
      "id": "emissions_trajectory",
      "name": "Emissions Trajectory",
      "order": 4,
      "type": "table",
      "description": "Baseline vs. retrofit emissions versus science-based or regulatory pathway target. The trajectory chart is the primary deliverable for green financing applications and investor ESG reporting.",
      "data_path": "retrofit_trajectory",
      "columns": [
        { "header": "Year",                         "data_key": "year",                       "width": 10, "format": "#,##0" },
        { "header": "Baseline (tCO₂e)",             "data_key": "baseline_emissions_tco2e",   "width": 20, "format": "#,##0.0" },
        { "header": "Retrofit (tCO₂e)",             "data_key": "retrofit_emissions_tco2e",   "width": 20, "format": "#,##0.0" },
        { "header": "Pathway Target (tCO₂e)",       "data_key": "pathway_target_tco2e",       "width": 22, "format": "#,##0.0", "omit_if_all_null": true },
        { "header": "Reduction vs. Baseline (%)",   "data_key": "reduction_vs_baseline_pct",  "width": 24, "format": "0.0%", "computed": "1 - (retrofit_emissions_tco2e / baseline_emissions_tco2e)" },
        { "header": "Pathway Gap (tCO₂e)",          "data_key": "pathway_gap_tco2e",          "width": 20, "format": "#,##0.0", "computed": "retrofit_emissions_tco2e - pathway_target_tco2e", "omit_if_source_null": "pathway_target_tco2e" }
      ],
      "conditional_formatting": {
        "pathway_gap_tco2e": [
          { "condition": "<= 0",  "fill": "#D1FAE5", "font_color": "#065F46", "note": "Aligned with or below pathway target" },
          { "condition": "> 0",   "fill": "#FFFBEB", "font_color": "#92400E", "note": "Above pathway target — gap exists" }
        ]
      },
      "charts": [
        {
          "id": "emissions_trajectory_chart",
          "type": "LineChart",
          "title": "Emissions Trajectory: Baseline vs. Retrofit vs. Pathway",
          "x_axis": "year",
          "series": [
            { "label": "Baseline",         "data_key": "baseline_emissions_tco2e",  "color": "#EF4444", "dash": "solid" },
            { "label": "Retrofit",         "data_key": "retrofit_emissions_tco2e",  "color": "primary",  "dash": "solid" },
            { "label": "Pathway Target",   "data_key": "pathway_target_tco2e",      "color": "#6B7280",  "dash": "dashed", "omit_if_all_null": true }
          ],
          "y_axis_label": "tCO₂e",
          "placement": "right_of_table",
          "width_cols": 12,
          "height_rows": 20,
          "note": "This chart is suitable for direct inclusion in green financing applications and investor ESG reporting packages."
        }
      ],
      "freeze_panes": "B2"
    },

    {
      "id": "additional_opportunities",
      "name": "Additional Opportunities",
      "order": 5,
      "type": "table",
      "description": "Supplemental measures from analysis that were not included in the primary plan. Presented for future consideration — not in plan totals.",
      "data_path": "other_opportunities",
      "omit_if_empty": true,
      "columns": [
        { "header": "Measure",              "data_key": "name",               "width": 32 },
        { "header": "Description",          "data_key": "description",        "width": 60, "wrap": true },
        { "header": "Est. CapEx ($)",       "data_key": "estimated_capex",    "width": 18, "format": "$#,##0",  "omit_if_all_null": true },
        { "header": "Est. Annual Savings ($)","data_key": "estimated_savings", "width": 22, "format": "$#,##0",  "omit_if_all_null": true }
      ],
      "header_note": "From supplemental measure analysis — not included in plan totals. Estimates are indicative only and require engineering assessment before budgeting.",
      "row_height": 48
    }

  ],

  "workbook_style": {
    "header_font": "Inter",
    "body_font": "Inter",
    "header_fill_color": "brand.primary_color",
    "header_font_color": "#FFFFFF",
    "header_font_size": 9,
    "body_font_size": 9,
    "alternate_row_fill": "#F9FAFB",
    "tab_colors": {
      "Roadmap Summary":          "brand.primary_color",
      "Measures":                 "brand.highlight_color",
      "Financial Projection":     "brand.secondary_color",
      "Emissions Trajectory":     "#065F46",
      "Additional Opportunities": "#9CA3AF"
    },
    "print_settings": {
      "fit_to_page": true,
      "orientation": "landscape",
      "repeat_header_rows": 1
    }
  }
}
